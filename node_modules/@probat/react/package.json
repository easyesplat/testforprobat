{
    "name": "@probat/react",
    "version": "0.3.2",
    "description": "React SDK for Probat experimentation — CTR tracking, variant assignment, and more",
    "main": "./dist/index.js",
    "module": "./dist/index.mjs",
    "types": "./dist/index.d.ts",
    "exports": {
        ".": {
            "types": "./dist/index.d.ts",
            "react-server": "./dist/index.mjs",
            "import": "./dist/index.mjs",
            "require": "./dist/index.js",
            "default": "./dist/index.mjs"
        }
    },
    "files": [
        "dist",
        "src",
        "README.md"
    ],
    "scripts": {
        "build": "tsup && npm run postbuild",
        "postbuild": "echo '\"use client\";' | cat - dist/index.mjs > temp && mv temp dist/index.mjs && echo '\"use client\";' | cat - dist/index.js > temp && mv temp dist/index.js",
        "dev": "tsup --watch",
        "test": "vitest run",
        "test:watch": "vitest",
        "typecheck": "tsc --noEmit",
        "prepublishOnly": "npm run build"
    },
    "keywords": [
        "probat",
        "ab-testing",
        "experimentation",
        "react",
        "ctr"
    ],
    "sideEffects": false,
    "author": "Probat AI",
    "license": "MIT",
    "peerDependencies": {
        "react": ">=18.0.0"
    },
    "devDependencies": {
        "@testing-library/jest-dom": "^6.6.3",
        "@testing-library/react": "^16.1.0",
        "@types/react": "^18.2.0",
        "@types/react-dom": "^18.2.0",
        "jsdom": "^25.0.1",
        "react": "^18.2.0",
        "react-dom": "^18.2.0",
        "tsup": "^8.0.0",
        "typescript": "^5.0.0",
        "vitest": "^2.1.8"
    }
}
